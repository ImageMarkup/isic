{
  "name": "isic",
  "private": true,
  "license": "Apache-2.0",
  "devEngines": {
    "packageManager": {
      "name": "npm"
    }
  },
  "devDependencies": {
    "@tailwindcss/forms": "0.5.0",
    "@tailwindcss/typography": "0.5.2",
    "autoprefixer": "10.4.4",
    "buffer": "6.0.3",
    "daisyui": "2.13.6",
    "npm-run-all2": "9.0.0",
    "parcel": "2.12.0",
    "postcss": "8.4.12",
    "process": "0.11.10",
    "remixicon": "2.5.0",
    "rimraf": "6.1.3",
    "tailwindcss": "3.0.24"
  },
  "scripts": {
    "build": "npm-run-all --sequential build:clean build:parcel",
    "build:clean": "rimraf ./isic/core/static/core/dist",
    "build:parcel": "parcel build",
    "start": "parcel watch"
  },
  "targets": {
    "styles": {
      "source": "./node-src/styles.pcss",
      "distDir": "./isic/core/static/core/dist"
    },
    "doiCreationForm": {
      "source": "./node-src/doiCreationForm.ts",
      "distDir": "./isic/core/static/core/dist"
    },
    "cog": {
      "source": "./node-src/cog.mjs",
      "distDir": "./isic/core/static/core/dist"
    },
    "cog_styles": {
      "source": "./node-src/ol.css",
      "distDir": "./isic/core/static/core/dist"
    }
  },
  "browserslist": "> 0.5%",
  "postcss": {
    "plugins": {
      "postcss-nested": {},
      "tailwindcss": {}
    }
  },
  "dependencies": {
    "@tailwindcss/line-clamp": "^0.4.4",
    "django-s3-file-field": "^1.1.0",
    "ol": "^9.2.4"
  }
}
